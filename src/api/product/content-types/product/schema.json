{
  "kind": "collectionType",
  "collectionName": "products",
  "info": {
    "singularName": "product",
    "pluralName": "products",
    "displayName": "Product",
    "description": "B METERS product catalogue"
  },
  "options": { "draftAndPublish": true },
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "shortDescription": {
      "type": "text"
    },
    "description": {
      "type": "text"
    },
    "subcategory": {
      "type": "string"
    },
    "badge": {
      "type": "string"
    },
    "specs": {
      "type": "json"
    },
    "sortOrder": {
      "type": "integer",
      "default": 99
    },
    "image": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "datasheet": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["files"]
    },
    "category": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::product-category.product-category",
      "inversedBy": "products"
    }
  }
}
